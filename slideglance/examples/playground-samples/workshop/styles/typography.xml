<Fragment>
  <Styles>
    <!-- Display + section heads -->
    <Style name="display-lg" fontFamily="Inter" fontSize="44" bold="true"  color="2A2118" lineHeight="1.1" />
    <Style name="display-md" fontFamily="Inter" fontSize="32" bold="true"  color="2A2118" lineHeight="1.15" />
    <Style name="title"      fontFamily="Inter" fontSize="22" bold="true"  color="2A2118" lineHeight="1.2" />
    <Style name="subtitle"   fontFamily="Inter" fontSize="16" bold="false" color="463729" lineHeight="1.35" />

    <!-- Body -->
    <Style name="body"       fontFamily="Inter" fontSize="14" bold="false" color="463729" lineHeight="1.3" />
    <Style name="body-lead"  fontFamily="Inter" fontSize="16" bold="false" color="2A2118" lineHeight="1.2" />
    <Style name="body-soft"  fontFamily="Inter" fontSize="13" bold="false" color="6E5A45" lineHeight="1.2" />

    <!-- Meta -->
    <Style name="eyebrow" fontFamily="Inter" fontSize="11" bold="true"  color="EF6C42" lineHeight="1.0" />
    <Style name="caption" fontFamily="Inter" fontSize="11" bold="true"  color="6E5A45" lineHeight="1.2" />

    <!-- Code -->
    <Style name="code"          fontFamily="JetBrains Mono" fontSize="12" color="FAEFD8" lineHeight="1.2" />
    <Style name="code-soft"     fontFamily="JetBrains Mono" fontSize="12" color="A18B72" lineHeight="1.2" />
    <Style name="code-keyword"  fontFamily="JetBrains Mono" fontSize="12" color="EF6C42" lineHeight="1.2" bold="true" />
    <Style name="code-string"   fontFamily="JetBrains Mono" fontSize="12" color="C6EBE3" lineHeight="1.2" />
    <Style name="code-comment"  fontFamily="JetBrains Mono" fontSize="12" color="A18B72" italic="true" lineHeight="1.2" />

    <!-- Inline accents -->
    <Style name="kw-coral" color="EF6C42" bold="true" />
    <Style name="kw-teal"  color="0F766E" bold="true" />
    <Style name="kw-mono"  fontFamily="JetBrains Mono" fontSize="13" color="2A2118" />

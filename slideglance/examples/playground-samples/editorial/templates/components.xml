<Fragment>
  <!--
    Reusable editorial components.

      pull-quote   — large italic quote with red leading bar.
      figure-card  — paper-tone card with caption underneath.
      stat-figure  — display number, label, and source line.
      footnote     — small italic source-line.
  -->
  <Templates>
    <Template name="pull-quote">
      <HStack gap="20" alignItems="start" w="100%">
        <VStack class="bg-accent" w="2" h="100%" />
        <VStack gap="8" w="max">
          <Text class="pull-quote">"{quote}"</Text>
          <Text class="caption">— {attribution}</Text>
        </VStack>
      </HStack>
    </Template>

    <Template name="figure-card">
      <VStack gap="8" w="100%">
        <VStack class="bg-figure" w="100%" h="220" borderRadius="2"
                alignItems="center" justifyContent="center">
          <Text fontFamily="Georgia" fontSize="14" italic="true" color="6B604F">{figureCaption}</Text>
        </VStack>
        <Text class="caption">FIGURE {n}  ·  {caption}</Text>
      </VStack>
    </Template>

    <Template name="stat-figure">
      <VStack gap="4" w="100%">
        <Text fontFamily="Georgia" fontSize="44" bold="true" color="1F1B16" lineHeight="1.0">{value}</Text>
        <Text class="caption">{label}</Text>
        <Text class="body-muted">{source}</Text>
      </VStack>
    </Template>

    <Template name="footnote">
      <Text fontFamily="Inter" fontSize="9" italic="true" color="6B604F" lineHeight="1.3"><Span bold="true">{n}.</Span> {body}</Text>
    </Template>
  </Templates>
</Fragment>

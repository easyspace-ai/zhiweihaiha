<Fragment>
  <!--
    Editorial type ramp. A serif display (Georgia) carries the
    voice; sans-serif (Inter) for captions, eyebrows, and meta.
    Bigger leading throughout — this is a long-read book, not a
    pitch deck.
  -->
  <Styles>
    <!-- Display -->
    <Style name="hero"       fontFamily="Georgia" fontSize="64" bold="false" color="1F1B16" lineHeight="1.0" />
    <Style name="display-lg" fontFamily="Georgia" fontSize="42" bold="false" color="1F1B16" lineHeight="1.1" />
    <Style name="display-md" fontFamily="Georgia" fontSize="30" bold="false" color="1F1B16" lineHeight="1.15" />
    <Style name="title"      fontFamily="Georgia" fontSize="22" bold="true"  color="1F1B16" lineHeight="1.2"  />
    <Style name="subtitle"   fontFamily="Georgia" fontSize="16" italic="true" color="3A332B" lineHeight="1.4" />

    <!-- Body -->
    <Style name="body"       fontFamily="Georgia" fontSize="12" bold="false" color="3A332B" lineHeight="1.5"  />
    <Style name="body-lead"  fontFamily="Georgia" fontSize="13" bold="false" color="1F1B16" lineHeight="1.5"  />
    <Style name="body-muted" fontFamily="Georgia" fontSize="12" italic="true" color="6B604F" lineHeight="1.45" />

    <!-- Sans-serif meta -->
    <Style name="eyebrow"   fontFamily="Inter" fontSize="9"  bold="true" color="9A2A1F" lineHeight="1.0" />
    <Style name="caption"   fontFamily="Inter" fontSize="9"  bold="true" color="6B604F" lineHeight="1.2" />
    <Style name="byline"    fontFamily="Inter" fontSize="10" bold="false" color="6B604F" italic="true" lineHeight="1.3" />
    <Style name="folio"     fontFamily="Inter" fontSize="10" bold="true" color="6B604F" />

    <!-- Pull quote -->
    <Style name="pull-quote" fontFamily="Georgia" fontSize="22" italic="true" color="1F1B16" lineHeight="1.3" />

    <!-- Inline accents -->
    <Style name="kw-accent"  color="9A2A1F" bold="true" />
    <Style name="kw-mustard" color="C28A1C" bold="true" />
  </Styles>
</Fragment>

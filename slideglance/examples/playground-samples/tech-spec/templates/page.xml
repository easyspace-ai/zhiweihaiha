<Fragment>
  <Templates>
    <Template name="cover-page">
      <Slide master="COVER">
        <VStack padding.left="80" padding.right="80"
                padding.top="140" padding.bottom="80"
                gap="24" h="100%" justifyContent="center">
          <Slot name="default" />
        </VStack>
      </Slide>
    </Template>

    <Template name="section">
      <Slide master="DOC">
        <VStack padding.left="56" padding.right="56"
                padding.top="80" padding.bottom="80"
                gap="20" h="100%">
          <VStack gap="6">
            <HStack gap="10" alignItems="center">
              <VStack class="bg-accent" w="14" h="2" />
              <Text class="eyebrow">{eyebrow}</Text>
            </HStack>
            <Text class="display-md">{title}</Text>
            <Text class="subtitle" w="820">{lede}</Text>
          </VStack>
          <VStack class="hairline" />
          <VStack class="fill" gap="16">
            <Slot name="default" />
          </VStack>
        </VStack>
      </Slide>
    </Template>
  </Templates>
</Fragment>

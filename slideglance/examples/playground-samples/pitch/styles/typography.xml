<Fragment>
  <!--
    Pitch type ramp. Inter for everything; large display weights
    carry rhetorical heft on a 16:9 stage. Monospace lives in the
    metric tickers so big numbers feel engineered, not editorial.
  -->
  <Styles>
    <!-- Display (hero/cover only) -->
    <Style name="hero"       fontFamily="Inter" fontSize="72" bold="true"  color="F5F5FA" lineHeight="1.02" />
    <Style name="hero-soft"  fontFamily="Inter" fontSize="72" bold="false" color="C9C9DC" lineHeight="1.02" />

    <!-- Section/page titles -->
    <Style name="display-lg" fontFamily="Inter" fontSize="48" bold="true"  color="F5F5FA" lineHeight="1.05" />
    <Style name="display-md" fontFamily="Inter" fontSize="36" bold="true"  color="F5F5FA" lineHeight="1.1"  />
    <Style name="title"      fontFamily="Inter" fontSize="24" bold="true"  color="F5F5FA" lineHeight="1.15" />
    <Style name="subtitle"   fontFamily="Inter" fontSize="18" bold="false" color="C9C9DC" lineHeight="1.3"  />

    <!-- Body / supporting -->
    <Style name="body"       fontFamily="Inter" fontSize="16" bold="false" color="C9C9DC" lineHeight="1.4" />
    <Style name="body-soft"  fontFamily="Inter" fontSize="14" bold="false" color="8B8BA8" lineHeight="1.4" />
    <Style name="caption"    fontFamily="Inter" fontSize="11" bold="true"  color="8B8BA8" lineHeight="1.2" />

    <!-- Eyebrow (uppercase mini caption used as section labels) -->
    <Style name="eyebrow"    fontFamily="Inter" fontSize="11" bold="true"  color="2EE6CA" lineHeight="1.0" />

    <!-- Metric tickers -->
    <Style name="metric-num"   fontFamily="JetBrains Mono" fontSize="40" bold="true"  color="F5F5FA" lineHeight="1.0" />
    <Style name="metric-label" fontFamily="Inter"          fontSize="12" bold="true"  color="8B8BA8" lineHeight="1.2" />

    <!-- Inline accents -->
    <Style name="kw-accent"   color="7C5CFF" bold="true" />
    <Style name="kw-accent-2" color="2EE6CA" bold="true" />
  </Styles>
</Fragment>

{
  "name": "@slideglance/web-playground",
  "version": "0.1.3",
  "license": "MIT",
  "author": "Taehwan Kwag <dev@simplecore.kr>",
  "description": "Drag-and-drop SPA for evaluating slideglance against arbitrary .pptx decks.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SlideGlance/slideglance.git",
    "directory": "apps/web-playground"
  },
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/run-build-wasm.mjs",
    "dev": "vite",
    "prebuild": "node ../../scripts/run-build-wasm.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check ."
  },
  "dependencies": {
    "@phosphor-icons/react": "catalog:",
    "@slideglance/core": "workspace:*",
    "@slideglance/viewer": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-top-level-await": "catalog:",
    "vite-plugin-wasm": "catalog:"
  }
}

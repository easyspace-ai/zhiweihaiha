{
  "name": "slide-builder",
  "private": true,
  "displayName": "SlideGlance PPTX Viewer",
  "description": "PPTX viewer and SlideGlance authoring workbench — live preview for .sgx files, custom editor for .pptx, one-command PPTX export.",
  "version": "0.1.3",
  "publisher": "simplecore",
  "author": "Taehwan Kwag <dev@simplecore.kr>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SlideGlance/slideglance.git",
    "directory": "apps/vscode-extension"
  },
  "engines": {
    "node": ">=22",
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "presentation",
    "pptx",
    "slides",
    "deck",
    "preview"
  ],
  "extensionDependencies": [
    "redhat.vscode-xml"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "activationEvents": [
    "workspaceContains:**/*.sgx",
    "onCustomEditor:slideBuilder.pptxViewer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "xml",
        "extensions": [
          ".sgx"
        ],
        "aliases": [
          "SlideGlance XML"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "slideBuilder.pptxViewer",
        "displayName": "SlideGlance PPTX Viewer",
        "selector": [
          {
            "filenamePattern": "*.pptx"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "slideBuilder.openPreview",
        "title": "SlideGlance: Open Preview",
        "icon": {
          "dark": "icons/preview-dark.svg",
          "light": "icons/preview-light.svg"
        }
      },
      {
        "command": "slideBuilder.refreshPreview",
        "title": "SlideGlance: Refresh Preview",
        "icon": {
          "dark": "icons/refresh-dark.svg",
          "light": "icons/refresh-light.svg"
        }
      },
      {
        "command": "slideBuilder.exportPptx",
        "title": "SlideGlance: Export PPTX",
        "icon": {
          "dark": "icons/export-dark.svg",
          "light": "icons/export-light.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "slideBuilder.isActive",
          "command": "slideBuilder.openPreview",
          "group": "navigation"
        },
        {
          "when": "slideBuilder.isActive",
          "command": "slideBuilder.exportPptx",
          "group": "navigation"
        },
        {
          "when": "activeWebviewPanelId == 'slideBuilderPreview'",
          "command": "slideBuilder.refreshPreview",
          "group": "navigation"
        },
        {
          "when": "activeWebviewPanelId == 'slideBuilderPreview'",
          "command": "slideBuilder.exportPptx",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build:host": "node esbuild.mjs",
    "build:webview": "vite build --config vite.webview.config.ts",
    "build:deps": "pnpm -r --filter '...slide-builder' --if-present build",
    "build": "pnpm run build:webview && pnpm run build:host",
    "watch:host": "node esbuild.mjs --watch",
    "lint": "eslint",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "pnpm run build:deps && pnpm run build",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@slideglance/builder": "workspace:*",
    "@slideglance/core": "workspace:*",
    "@slideglance/measure": "workspace:*",
    "@slideglance/viewer": "workspace:*",
    "@types/node": "^25.6.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "catalog:",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.28.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.2",
    "vite": "catalog:",
    "vite-plugin-top-level-await": "catalog:",
    "vite-plugin-wasm": "catalog:"
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SlideGlance",
  "version": "0.1.3",
  "identifier": "com.slideglance.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm --filter @slideglance/desktop-viewer dev",
    "beforeBuildCommand": "pnpm --filter @slideglance/desktop-viewer build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SlideGlance",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "dragDropEnabled": true,
        "decorations": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

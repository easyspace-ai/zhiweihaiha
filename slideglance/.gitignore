*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Test artifacts
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# VRT diff outputs (kept locally only)
testing/vrt/snapshot/diffs/
testing/vrt/libreoffice/diffs/
testing/vrt/snapshot/fixtures/
testing/vrt/libreoffice/fixtures/
testing/vrt/json-diff/artifacts/

# Env
.env
.env.local
.env.*.local

# Misc
.cache/
tmp/

.claude/
.compare/

# Git worktrees (subagent-driven-development isolated workspaces)
.worktrees/

# `tauri icon` writes a fan-out of mobile and Windows-Store assets we
# don't ship — desktop-viewer is desktop-only. Keep only the files
# tauri.conf.json's `bundle.icon` references plus icon.png (the source
# Tauri reads at build time). Re-run `scripts/build-icons.sh` to
# regenerate everything from `assets/icon/source.svg`.
apps/desktop-viewer/src-tauri/icons/64x64.png
apps/desktop-viewer/src-tauri/icons/Square*Logo.png
apps/desktop-viewer/src-tauri/icons/StoreLogo.png
apps/desktop-viewer/src-tauri/icons/ios/
apps/desktop-viewer/src-tauri/icons/android/
output/

# Packaged VS Code extension bundles (reproducible via `vsce package`)
*.vsix
{
  "name": "gusheng-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=8123 --host=0.0.0.0",
    "dev:ppthtml-export": "npm --prefix server/ppthtml-export run start",
    "postinstall:ppthtml-export": "npm install --prefix server/ppthtml-export",
    "dev:ppthtml": "pnpm run dev:ppthtml-export & vite --port=8123 --host=0.0.0.0",
    "build:slideglance-deps": "node ../slideglance/scripts/run-build-wasm.mjs && pnpm --filter @slideglance/builder --filter @slideglance/viewer build && find ../slideglance/packages/core/dist ../slideglance/packages/measure/dist -name .gitignore -delete",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "build:embed-backend": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@slideglance/builder": "workspace:*",
    "@slideglance/core": "workspace:*",
    "@slideglance/measure": "workspace:*",
    "@slideglance/viewer": "workspace:*",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.99.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "handlebars": "^4.7.9",
    "html2pdf.js": "^0.14.0",
    "i18next": "^26.0.4",
    "lightweight-charts": "5.1.0",
    "lucide-react": "^0.546.0",
    "markdown-docx": "^1.6.0",
    "marked": "^14.0.0",
    "motion": "^12.38.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.3",
    "react-is": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.28.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.175.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "wordcloud": "^1.2.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "vitest": "catalog:",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}

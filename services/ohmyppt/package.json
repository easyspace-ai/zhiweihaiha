{
  "name": "@osinttools/ohmyppt-service",
  "version": "0.3.0",
  "description": "Headless HTTP service for oh-my-ppt deck generation (copy-based architecture)",
  "license": "MIT",
  "type": "module",
  "imports": {
    "@shared/*": "./src/shared/*",
    "electron": "./src/adapters/electron-stub.ts",
    "electron-log/main.js": "./src/adapters/electron-log-stub.ts",
    "@electron-toolkit/utils": "./src/adapters/electron-toolkit-stub.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "pack": "node scripts/pack.mjs",
    "postinstall": "node scripts/link-electron-shims.mjs && node scripts/install-playwright.mjs",
    "playwright:install": "node scripts/install-playwright.mjs",
    "start": "node --import tsx src/index.ts",
    "test": "npx vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.6",
    "@hono/node-server": "^1.14.4",
    "@langchain/anthropic": "^1.3.29",
    "@langchain/core": "^1.1.47",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/openai": "^1.4.5",
    "@libsql/client": "^0.14.0",
    "@node-rs/jieba": "^2.0.1",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "deepagents": "^1.10.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "electron-log": "^5.4.4",
    "fflate": "^0.8.2",
    "fonteditor-core": "^2.6.3",
    "hono": "^4.7.11",
    "isomorphic-git": "^1.37.6",
    "katex": "^0.16.45",
    "langchain": "^1.4.1",
    "lru-cache": "^11.5.0",
    "nanoid": "^5.1.9",
    "p-limit": "^3.1.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.52.0",
    "pptxtojson": "^2.0.2",
    "tiktoken": "^1.0.18",
    "turndown": "^7.2.4",
    "woff2-encoder": "^2.0.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "esbuild": "^0.25.12",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

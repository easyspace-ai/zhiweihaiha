# 复制本文件到仓库根目录并重命名为 .env（与 backend/、frontend/ 同级）。
# 也可通过环境变量 DOTENV_PATH 指定任意 .env 路径。
# 必填（所有配置以本文件为准，无代码内默认）
DATABASE_URL=./youmind.db
JWT_SECRET=your-secret-here

# 系统情报技能 JSON：defaults 为出厂基线，custom 为超级管理员覆盖（合并后写入 DB，全局共享）
# SKILLS_DEFAULTS_DIR=./data/skills/defaults
# SKILLS_CUSTOM_DIR=./data/skills/custom
# 情报报告 MD 轻度排版 + 纵向 HTML 参考（默认自动发现仓库根 osint-report-skill/）
# OSINT_REPORT_SKILL_DIR=./osint-report-skill

# 可选
APP_NAME=YouMind Backend v2
APP_ENV=development
HTTP_PORT=8080
# 日志：默认开发环境写入 ./logs/backend.log，并继续输出到 stdout
# LOG_FILE_PATH=
# LOG_TO_STDOUT=true
# 前端构建产物目录（可选）。不设时：若二进制同目录存在 static/ 则自动使用（如根目录 make 后的 bin/static），否则使用进程工作目录下的 static/
# STATIC_DIR=/path/to/static

# access token 有效期（分钟）。默认 525600 = 365 天；仅用户主动退出才需重新登录
ACCESS_TOKEN_EXPIRE_MINUTES=525600
# 已废弃区分：登录一律使用 ACCESS_TOKEN_EXPIRE_MINUTES；保留变量仅为兼容旧 .env
ACCESS_TOKEN_SESSION_EXPIRE_MINUTES=525600

# CORS：APP_ENV=production 时必须配置逗号分隔白名单；开发环境可留空（允许任意 Origin）
# CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173

# 每 IP 每分钟请求上限（/api 与 /api/auth 分别计数）
# RATE_LIMIT_API_PER_MINUTE=180
# RATE_LIMIT_AUTH_PER_MINUTE=30

# 每轮对话成功结束后扣减的积分（0 关闭）；需用户 credits_balance 足够才会开始对话
# CHAT_CREDIT_COST=1

# OpenAI 兼容 API（对话用）
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4.1-mini

# DeepSeek API（管理后台技能编写 AI 助手 + HTML Studio 流水线）
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_TIMEOUT_SEC=120
# DEEPSEEK_PIPELINE_STAGE_TIMEOUT_SEC=300
# DEEPSEEK_PIPELINE_TOTAL_TIMEOUT_SEC=900

# Guizang HTML PPT：guizang-ppt-skill 模板目录（默认 ~/.claude/skills/guizang-ppt-skill）
# GUIZANG_SKILL_DIR=/path/to/guizang-ppt-skill

# Oh My PPT headless 服务（Node，默认 http://127.0.0.1:6130）
# 启动时会读取仓库根目录 .env 中的 DEEPSEEK_* 作为 LLM 配置（与 Studio 流水线共用）
# OHMYPPT_SERVICE_URL=http://127.0.0.1:6130

# 独立 AI SDK（推荐）
# 若不设置，将自动回退到 OPENAI_COMPAT_* 配置
AI_SDK_BASE_URL=https://api.openai.com/v1
# third-party key, sent as x-w6service-api-key
AI_SDK_SERVICE_API_KEY=
AI_SDK_UPLOAD_PATH=/api/upload
AI_SDK_TIMEOUT_SEC=120
# WebSocket 写帧超时（{"id"} / input / Stop）
AI_SDK_WS_WRITE_TIMEOUT_SEC=8
# WebSocket 握手超时（等待 update.state.id + status）
AI_SDK_WS_HANDSHAKE_TIMEOUT_SEC=15
# WebSocket 建连超时（Dial）
AI_SDK_WS_DIAL_TIMEOUT_SEC=15
AI_SDK_RETRY_MAX=2
# 设为 true 时回滚到旧的 ai.NewFromEnv 实现
AI_SDK_LEGACY_MODE=false
# 调试：打印 SDK WebSocket 帧、上游 GET、EnsureSession / upstream-gate 等详细日志（生产勿开）
AI_SDK_DEBUG=false
# GORM SQL 日志（默认关闭；开启后会刷屏 UPDATE resources 等语句）
# GORM_LOG_SQL=true

# 后台静默发消息：发送后确认窗口与重试（sessionsend 模块）
# SESSION_SEND_VERIFY_TIMEOUT_SEC=30
# SESSION_SEND_VERIFY_POLL_SEC=2
# SESSION_SEND_MAX_RETRIES=3

# Dashboard 聚合推送目标 W6 会话
# DASHBOARD_SESSION_ID=
# 与 XStream 同步周期一致：每 10 分钟拉取；未推送新消息 > DASHBOARD_PUSH_MIN_ITEMS 时推 W6 一次
# XSTREAM_FETCH_INTERVAL=10m
# 监测流分类/数据上游（默认 risk.haina.info，一般无需修改）
# XSTREAM_GROUP_API_URL=https://risk.haina.info/api/Monitor/queryMonitorStreamGroup
# DASHBOARD_PUSH_MIN_ITEMS=5
# DASHBOARD_AGGREGATE_INTERVAL=10m

# W6 AI 网关配置（用于课程大纲 / 网页生成）
# 如果不使用 W6，可以留空；使用时至少需要 BASE_URL、WSS_BASE_URL 和鉴权字段。
W6_BASE_URL=https://beta.megamoyo.cn/api
W6_WSS_BASE_URL=wss://beta.megamoyo.cn/api/interact/chat/
W6_AUTH_HEADER_FIELD=x-w6-api-key
W6_AUTH_HEADER_VALUE=
W6_MODEL_PROCEDURE=raw
W6_MODEL_LLM=claude-3.7-sonnet
W6_MODEL_LLM_SHORT=Claude
W6_MODULE_NAME=w6.agent.third_party.iecube
